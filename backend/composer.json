{
    "name": "school-management-system/backend",
    "description": "School Management System Backend API",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "yiisoft/yii-runner-http": "^2.0",
        "yiisoft/di": "^1.0",
        "yiisoft/config": "^1.0",
        "yiisoft/yii-http": "^1.0",
        "yiisoft/router": "^3.0",
        "yiisoft/router-fastroute": "^3.0",
        "yiisoft/middleware-dispatcher": "^5.0",
        "yiisoft/db": "^1.0",
        "yiisoft/db-mysql": "^1.0",
        "yiisoft/cache": "^3.0",
        "yiisoft/cache-redis": "^2.0",
        "yiisoft/validator": "^1.0",
        "yiisoft/log": "^2.0",
        "yiisoft/log-target-file": "^3.0",
        "firebase/php-jwt": "^6.0",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "yiisoft/yii-debug": "^2.0||dev-master",
        "giorgiosironi/eris": "^0.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "yiisoft/config": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}

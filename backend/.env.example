# 数据库配置（使用主项目的MySQL）
DB_HOST=localhost
DB_NAME=xrugc
DB_USER=root
DB_PASSWORD=

# Redis配置（使用主项目的Redis）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT配置
JWT_SECRET=your-secret-key-here
JWT_EXPIRE=3600

# 应用配置
APP_ENV=development
APP_DEBUG=true

# PSR-15 中间件栈配置
# 设置为 true 启用 PSR-15 中间件栈（用于逐步迁移）
# 设置为 false 完全禁用 PSR-15 路由，使用传统路由
# 此环境变量优先级高于 config/psr15-migration.php 中的 'enabled' 配置
PSR15_ENABLED=true

# ============================================================
# 学校管理系统 - 环境变量配置
# School Management System - Environment Variables
# ============================================================
# 复制此文件为 .env 并修改配置值
# Copy this file to .env and update the values
# ============================================================

# ── 应用配置 (Application Settings) ─────────────────────────
# 环境: development | production
APP_ENV=development
# 调试模式: 生产环境必须设为 false
APP_DEBUG=true
# 应用访问地址
APP_URL=http://localhost:3002

# ── 数据库配置 (Database - Shared MySQL) ────────────────────
# 与主系统共享的 MySQL 数据库
# Docker 环境使用 host.docker.internal 访问宿主机
DB_HOST=localhost
DB_PORT=3306
DB_NAME=xrugc
DB_USER=root
DB_PASSWORD=

# ── Redis 配置 (Redis - Shared Cache) ──────────────────────
# 与主系统共享的 Redis 缓存和会话存储
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT 配置 (JWT Authentication) ───────────────────────────
# JWT 签名密钥 - 生产环境必须修改！
# 生成方式: openssl rand -hex 32
JWT_SECRET=your-secret-key-change-this-in-production
# Token 过期时间（秒），默认 1 小时
JWT_EXPIRY=3600

# ── CORS 配置 (Cross-Origin Resource Sharing) ──────────────
# 允许的前端域名，逗号分隔
CORS_ALLOWED_ORIGINS=http://localhost:3002,http://localhost:8080

# ── 前端配置 (Frontend) ─────────────────────────────────────
# 后端 API 地址（前端构建时使用）
VITE_API_BASE_URL=/api
# 主系统地址（用于跳转回主系统）
VITE_MAIN_SYSTEM_URL=http://localhost:8080

# ── 日志配置 (Logging) ──────────────────────────────────────
# 日志级别: debug | info | warning | error
LOG_LEVEL=debug
# 日志文件保留天数
LOG_MAX_FILES=7
